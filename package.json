{
  "name": "holonet",
  "version": "1.0.0",
  "description": "DevOps-First API Client & AI Agent Interface",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"server,client\" -c \"blue,magenta\" \"pnpm --filter server dev\" \"pnpm --filter client dev\"",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm -r build",
    "build:client": "pnpm --filter client build",
    "build:server": "pnpm --filter server build",
    "dist": "pnpm --filter client dist",
    "dist:win": "pnpm --filter client dist:win",
    "dist:mac": "pnpm --filter client dist:mac",
    "dist:linux": "pnpm --filter client dist:linux",
    "db:generate": "pnpm --filter server db:generate",
    "db:migrate": "pnpm --filter server db:migrate",
    "db:studio": "pnpm --filter server db:studio",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/ui": "^1.0.4",
    "concurrently": "^9.2.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "tar": "7.4.3",
      "minipass": "^7.0.0",
      "minizlib": "^3.0.0"
    }
  },
  "dependencies": {
    "@langchain/core": "^1.1.29",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/openai": "^1.2.11",
    "zod": "^3.25.76"
  }
}
